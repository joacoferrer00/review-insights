# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit real keys.

# --- Apify ---
APIFY_API_KEY=

# --- LLM Provider ---
# Options: "gemini" | "openai"
LLM_PROVIDER=gemini

# Model name (provider-specific)
# gemini examples: gemini-2.0-flash, gemini-2.5-flash
# openai examples: gpt-4o-mini, gpt-4.1-mini
LLM_MODEL=gemini-2.5-flash

# API key for the chosen provider
LLM_API_KEY=

# --- Streamlit Cloud ---
# Base URL of the deployed Streamlit app (no trailing slash, no ?client=...)
# Used by the pipeline to print the dashboard link at the end of each run.
STREAMLIT_URL=

# --- Optional ---
# Default temperature for classification (low = deterministic)
LLM_TEMPERATURE=0.0

# Max retries on JSON validation failure
LLM_MAX_RETRIES=2

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
